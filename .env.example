# ─── رفع على Hostinger VPS ────────────────────────────────────────────────────
# انسخ هذا الملف إلى .env وعدّل القيم قبل تشغيل docker compose

# النطاق الرئيسي
DOMAIN=bazar.bh

# كلمة مرور قاعدة البيانات (اختر كلمة مرور قوية)
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# المفتاح السري لـ JWT (قيمة عشوائية طويلة)
JWT_SECRET=CHANGE_THIS_64_CHAR_RANDOM_SECRET

# ─── خدمات اختيارية ──────────────────────────────────────────────────────────
# SMTP للإيميل
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=no-reply@bazar.bh
SMTP_PASS=

# Twilio للـ SMS (اختياري)
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=
