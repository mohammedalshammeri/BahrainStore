// This is your Prisma schema file for Bazar Platform
// Developer: BSMC.BH

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// MERCHANTS (التجار)
// ─────────────────────────────────────────────
model Merchant {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)
  isAdmin       Boolean   @default(false)
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  googleId         String?   @unique
  passwordResetToken    String?   @unique
  passwordResetExpires  DateTime?
  lastLoginIp      String?
  lastLoginAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  kycStatus     String    @default("NONE") // NONE | PENDING | APPROVED | REJECTED

  stores        Store[]
  sessions      Session[]
  staffMemberships StoreStaff[]
  platformReferrals MerchantReferral[]
  kycDocuments  KycDocument[]
  termsAcceptances TermsAcceptance[]

  @@map("merchants")
}

model Session {
  id           String   @id @default(cuid())
  merchantId   String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  merchant     Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─────────────────────────────────────────────
// STORES (المتاجر)
// ─────────────────────────────────────────────
model Store {
  id           String      @id @default(cuid())
  merchantId   String
  name         String
  nameAr       String
  slug         String      @unique
  description  String?
  descriptionAr String?
  logo         String?
  favicon      String?
  ogImage      String?
  domain       String?     @unique
  subdomain    String      @unique
  currency     String      @default("BHD")
  language     StoreLanguage @default(BOTH)
  timezone     String      @default("Asia/Bahrain")
  vatNumber    String?
  crNumber     String?
  vatRate      Decimal     @default(0.05) @db.Decimal(5, 4)
  isActive     Boolean     @default(true)
  plan         StorePlan   @default(STARTER)
  planExpiresAt DateTime?
  trialEndsAt  DateTime?
  gracePeriodEnds DateTime?   // grace period after failed subscription payment
  paymentRetryCount Int      @default(0)
  apiKey          String?     @unique
  apiKeyEnabled   Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  merchant     Merchant    @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  products     Product[]
  categories   Category[]
  orders       Order[]
  customers    Customer[]
  coupons      Coupon[]
  pages        Page[]
  settings     StoreSettings?
  staff        StoreStaff[]
  abandonedCarts AbandonedCart[]
  pageViews      PageView[]
  loyaltyTx      LoyaltyTransaction[]
  billingInvoices BillingInvoice[]
  installedApps  InstalledApp[]
  blogPosts      BlogPost[]
  reviews        Review[]
  flashSales     FlashSale[]
  webhooks       Webhook[]
  referralCodes  ReferralCode[]
  backInStockSubs BackInStockSubscription[]
  giftCards      GiftCard[]
  supportTickets SupportTicket[]
  onboarding     Onboarding?
  popups         Popup[]
  emailCampaigns   EmailCampaign[]
  emailSubscribers EmailSubscriber[]
  upsellRules      UpsellRule[]
  countdownTimers  CountdownTimer[]
  domainVerification DomainVerification?
  smsCampaigns     SmsCampaign[]
  pushSubscriptions PushSubscription[]
  pushCampaigns    PushNotificationCampaign[]
  posOrders        PosOrder[]
  posSessions      PosSession[]
  importJobs       ImportJob[]
  warehouses       Warehouse[]
  liveStreams      LiveStream[]
  liveChatSessions LiveChatSession[]
  socialIntegrations SocialIntegration[]
  b2bInvoices      B2BInvoice[]
  zatcaInvoices    ZatcaInvoice[]
  shippingZones    ShippingZone[]
  shoppingFeed     ShoppingFeed?
  productViews     ProductView[]
  themePurchases   ThemePurchase[]
  subscriptions    CustomerSubscription[]
  merchantPayments MerchantPayment[]
  apiUsageLogs     ApiUsageLog[]

  @@map("stores")
}

model StoreSettings {
  id             String  @id @default(cuid())
  storeId        String  @unique
  primaryColor   String  @default("#2563eb")
  secondaryColor String  @default("#f97316")
  fontFamily     String  @default("Cairo")
  theme          String  @default("default")
  showOutOfStock Boolean @default(true)
  allowReviews   Boolean @default(true)
  freeShippingMin Decimal? @db.Decimal(10, 3)
  whatsappEnabled Boolean @default(false)
  whatsappPhoneId String?
  whatsappToken   String?
  // SMS (Twilio)
  smsEnabled      Boolean @default(false)
  smsTwilioSid    String?
  smsTwilioToken  String?
  smsTwilioFrom   String?
  // Aramex
  aramexEnabled   Boolean @default(false)
  aramexUser      String?
  aramexPassword  String?
  aramexAccountNumber String?
  aramexPinCode   String?
  // DHL
  dhlEnabled      Boolean @default(false)
  dhlApiKey       String?
  dhlAccountNumber String?
  // Tabby
  tabbyEnabled    Boolean @default(false)
  tabbyPublicKey  String?
  tabbySecretKey  String?
  // Tamara
  tamaraEnabled   Boolean @default(false)
  tamaraToken     String?
  // Apple Pay
  applePayEnabled    Boolean @default(false)
  applePayMerchantId String?
  // Google Pay
  googlePayEnabled    Boolean @default(false)
  googlePayMerchantId String?
  // Tap Payments
  tapEnabled         Boolean @default(false)
  tapSecretKey       String?
  tapPublicKey       String?
  tapWebhookSecret   String?
  // Moyasar
  moyasarEnabled     Boolean @default(false)
  moyasarSecretKey   String?
  moyasarPublicKey   String?
  // Benefit Pay (NBB)
  benefitEnabled     Boolean @default(false)
  benefitMerchantId  String?
  benefitApiKey      String?
  // Loyalty Program (نقاط الولاء)
  loyaltyEnabled      Boolean @default(false)
  loyaltyPointsPerBD  Int     @default(10)
  loyaltyBDPerPoint   Decimal @default(0.01) @db.Decimal(8, 4)
  loyaltyMinRedeem    Int     @default(100)
  loyaltyMaxRedeemPct Int     @default(20)
  // Referral Program (برنامج الإحالة)
  referralEnabled     Boolean @default(false)
  referralRewardType  String  @default("FIXED") // FIXED | PERCENTAGE
  referralRewardValue Decimal @default(1.000) @db.Decimal(10, 3)
  referralMinOrder    Decimal? @db.Decimal(10, 3)
  // Marketing Pixels (بكسلات التسويق)
  googleTagId         String?
  facebookPixelId     String?
  tiktokPixelId       String?
  snapchatPixelId     String?
  googleAdsId         String?
  // New Payment Gateways
  stripeEnabled       Boolean @default(false)
  stripeSecretKey     String?
  stripePublicKey     String?
  stripeWebhookSecret String?
  paytabsEnabled      Boolean @default(false)
  paytabsProfileId    String?
  paytabsSecretKey    String?
  paytabsRegion       String  @default("SAU")
  paypalEnabled       Boolean @default(false)
  paypalClientId      String?
  paypalSecret        String?
  paypalMode          String  @default("sandbox")
  stcpayEnabled       Boolean @default(false)
  stcpayMerchantId    String?
  stcpayApiKey        String?
  madaEnabled         Boolean @default(false)
  hyperpayEnabled     Boolean @default(false)
  hyperpayAccessToken String?
  hyperpayEntityId    String?
  postpayEnabled      Boolean @default(false)
  postpayApiUrl       String?
  postpayApiKey       String?
  // Multi-currency
  supportedCurrencies String[] @default(["BHD"])
  // Dark Mode
  darkModeEnabled     Boolean @default(false)
  // ZATCA
  zatcaEnabled        Boolean @default(false)
  zatcaVatNumber      String?
  zatcaCrNumber       String?
  // Homepage Page Builder
  homeBlocks          Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  store          Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("store_settings")
}

// ─────────────────────────────────────────────
// ABANDONED CARTS (السلل المتروكة)
// ─────────────────────────────────────────────
model AbandonedCart {
  id           String    @id @default(cuid())
  storeId      String
  email        String
  phone        String?
  firstName    String?
  cartData     Json
  reminderSent Boolean   @default(false)
  reminderSentAt DateTime?
  recoveredAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  store        Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, email])
  @@map("abandoned_carts")
}

// ─────────────────────────────────────────────
// PAGE VIEWS (تتبع الزيارات)
// ─────────────────────────────────────────────
model PageView {
  id        String   @id @default(cuid())
  storeId   String
  path      String
  referrer  String?
  source    String?  // direct | google | social | email | other
  country   String?
  createdAt DateTime @default(now())

  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, createdAt])
  @@map("page_views")
}

// ─────────────────────────────────────────────
// CATEGORIES (التصنيفات)
// ─────────────────────────────────────────────
model Category {
  id          String     @id @default(cuid())
  storeId     String
  parentId    String?
  name        String
  nameAr      String
  slug        String
  description String?
  image       String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  store       Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  parent      Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryChildren")
  products    Product[]

  @@unique([storeId, slug])
  @@map("categories")
}

// ─────────────────────────────────────────────
// PRODUCTS (المنتجات)
// ─────────────────────────────────────────────
model Product {
  id              String        @id @default(cuid())
  storeId         String
  categoryId      String?
  name            String
  nameAr          String
  slug            String
  description     String?
  descriptionAr   String?
  sku             String?
  barcode         String?
  price           Decimal       @db.Decimal(10, 3)
  comparePrice    Decimal?      @db.Decimal(10, 3)
  costPrice       Decimal?      @db.Decimal(10, 3)
  trackInventory  Boolean       @default(true)
  stock           Int           @default(0)
  lowStockAlert   Int           @default(5)
  weight          Decimal?      @db.Decimal(8, 3)
  isActive             Boolean  @default(true)
  isFeatured           Boolean  @default(false)
  isDigital            Boolean  @default(false)
  digitalFileUrl       String?
  isPreOrder           Boolean  @default(false)
  preOrderMessage      String?
  preOrderMessageAr    String?
  preOrderDeliveryDays Int?
  seoTitle             String?
  seoDescription       String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  store           Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category        Category?     @relation(fields: [categoryId], references: [id])
  images          ProductImage[]
  options         ProductOption[]
  variants        ProductVariant[]
  orderItems      OrderItem[]
  reviews         Review[]
  flashSaleItems  FlashSaleItem[]
  backInStockSubs BackInStockSubscription[]
  subscriptionPlans SubscriptionPlan[]
  liveStreamProducts LiveStreamProduct[]
  productViews    ProductView[]
  warehouseStocks WarehouseStock[]

  @@unique([storeId, slug])
  @@map("products")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int     @default(0)

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductOption {
  id        String         @id @default(cuid())
  productId String
  name      String
  nameAr    String
  sortOrder Int            @default(0)

  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  values    OptionValue[]

  @@map("product_options")
}

model OptionValue {
  id        String               @id @default(cuid())
  optionId  String
  value     String
  valueAr   String
  color     String?
  sortOrder Int                  @default(0)

  option        ProductOption        @relation(fields: [optionId], references: [id], onDelete: Cascade)
  variantValues VariantOptionValue[]

  @@map("option_values")
}

model VariantOptionValue {
  variantId     String
  optionValueId String

  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  optionValue OptionValue    @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@id([variantId, optionValueId])
  @@map("variant_option_values")
}

model ProductVariant {
  id           String   @id @default(cuid())
  productId    String
  name         String
  nameAr       String
  sku          String?
  barcode      String?
  price        Decimal  @db.Decimal(10, 3)
  comparePrice Decimal? @db.Decimal(10, 3)
  costPrice    Decimal? @db.Decimal(10, 3)
  stock        Int      @default(0)
  image        String?
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  product      Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems   OrderItem[]
  optionValues VariantOptionValue[]

  @@map("product_variants")
}

// ─────────────────────────────────────────────
// CUSTOMERS (العملاء)
// ─────────────────────────────────────────────
model Customer {
  id           String    @id @default(cuid())
  storeId      String
  email        String?
  phone        String
  firstName    String
  lastName     String
  passwordHash String?
  isGuest      Boolean   @default(false)
  totalOrders  Int       @default(0)
  totalSpent   Decimal   @default(0) @db.Decimal(10, 3)
  loyaltyPoints Int      @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  store        Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders       Order[]
  addresses    Address[]
  loyaltyTx    LoyaltyTransaction[]
  reviews      Review[]
  referralCodes ReferralCode[]
  subscriptions CustomerSubscription[]

  @@unique([storeId, phone])
  @@map("customers")
}

model Address {
  id         String   @id @default(cuid())
  customerId String
  label      String   @default("المنزل")
  firstName  String
  lastName   String
  phone      String
  block      String?
  road       String?
  building   String?
  flat       String?
  area       String
  city       String   @default("المنامة")
  country    String   @default("BH")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders     Order[]

  @@map("addresses")
}

// ─────────────────────────────────────────────
// ORDERS (الطلبات)
// ─────────────────────────────────────────────
model Order {
  id              String        @id @default(cuid())
  storeId         String
  customerId      String
  addressId       String?
  orderNumber     String
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentMethod   PaymentMethod
  subtotal        Decimal       @db.Decimal(10, 3)
  shippingCost    Decimal       @default(0) @db.Decimal(10, 3)
  vatAmount       Decimal       @default(0) @db.Decimal(10, 3)
  discountAmount  Decimal       @default(0) @db.Decimal(10, 3)
  total           Decimal       @db.Decimal(10, 3)
  couponCode      String?
  notes           String?
  trackingNumber  String?
  shippingCompany String?
  paymentReference String? // external payment gateway reference/session ID
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  store           Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer        Customer      @relation(fields: [customerId], references: [id])
  address         Address?      @relation(fields: [addressId], references: [id])
  items           OrderItem[]
  payment         Payment?
  returns         OrderReturn[]

  @@unique([storeId, orderNumber])
  @@map("orders")
}

model OrderItem {
  id        String          @id @default(cuid())
  orderId   String
  productId String
  variantId String?
  name      String
  nameAr    String
  sku       String?
  price     Decimal         @db.Decimal(10, 3)
  quantity  Int
  total     Decimal         @db.Decimal(10, 3)

  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id])
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

// ─────────────────────────────────────────────
// RETURNS (المرتجعات)
// ─────────────────────────────────────────────
model OrderReturn {
  id             String       @id @default(cuid())
  orderId        String
  returnNumber   String
  reason         String
  status         ReturnStatus @default(PENDING)
  refundAmount   Decimal      @default(0) @db.Decimal(10, 3)
  refundMethod   String?      // original_payment | store_credit | bank_transfer
  notes          String?
  processedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  order          Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items          ReturnItem[]

  @@unique([orderId, returnNumber])
  @@map("order_returns")
}

model ReturnItem {
  id          String      @id @default(cuid())
  returnId    String
  orderItemId String
  quantity    Int
  reason      String?

  orderReturn OrderReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@map("return_items")
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

// ─────────────────────────────────────────────
// PAYMENTS (المدفوعات)
// ─────────────────────────────────────────────
model Payment {
  id            String        @id @default(cuid())
  orderId       String        @unique
  method        PaymentMethod
  amount        Decimal       @db.Decimal(10, 3)
  currency      String        @default("BHD")
  status        PaymentStatus @default(PENDING)
  gatewayRef    String?
  gatewayResponse Json?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ─────────────────────────────────────────────
// COUPONS (الكوبونات)
// ─────────────────────────────────────────────
model Coupon {
  id            String      @id @default(cuid())
  storeId       String
  code          String
  type          CouponType
  value         Decimal     @db.Decimal(10, 3)
  minOrderValue Decimal?    @db.Decimal(10, 3)
  maxUses       Int?
  usedCount     Int         @default(0)
  isActive      Boolean     @default(true)
  expiresAt     DateTime?
  createdAt     DateTime    @default(now())

  store         Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  rules         CouponRule[]

  @@unique([storeId, code])
  @@map("coupons")
}

// ─────────────────────────────────────────────
// PAGES (صفحات المتجر)
// ─────────────────────────────────────────────
model Page {
  id          String    @id @default(cuid())
  storeId     String
  title       String
  titleAr     String
  slug        String
  content     String?
  contentAr   String?
  excerpt     String?
  pageType    PageType  @default(CUSTOM)
  isActive    Boolean   @default(true)
  seoTitle    String?
  seoDesc     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, slug])
  @@map("pages")
}

// ─────────────────────────────────────────────
// STORE STAFF (فريق المتجر)
// ─────────────────────────────────────────────
model StoreStaff {
  id            String    @id @default(cuid())
  storeId       String
  merchantId    String?
  email         String
  firstName     String
  lastName      String
  passwordHash  String?
  role          StaffRole @default(STAFF)
  isActive      Boolean   @default(true)
  inviteToken   String?   @unique
  inviteExpires DateTime?
  acceptedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  store         Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  merchant      Merchant? @relation(fields: [merchantId], references: [id])

  @@unique([storeId, email])
  @@map("store_staff")
}

// ─────────────────────────────────────────────
// LOYALTY (نقاط الولاء)
// ─────────────────────────────────────────────
model LoyaltyTransaction {
  id          String          @id @default(cuid())
  storeId     String
  customerId  String
  orderId     String?
  type        LoyaltyTxType
  points      Int
  description String?
  createdAt   DateTime        @default(now())

  store       Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer    Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([storeId, customerId])
  @@map("loyalty_transactions")
}

// ─────────────────────────────────────────────
// BILLING INVOICES (فواتير الاشتراك)
// ─────────────────────────────────────────────
model BillingInvoice {
  id            String               @id @default(cuid())
  storeId       String
  plan          StorePlan
  periodStart   DateTime
  periodEnd     DateTime
  amountBD      Decimal              @db.Decimal(10, 3)
  status        BillingInvoiceStatus @default(PENDING)
  paidAt        DateTime?
  paymentRef    String?
  invoiceNumber String               @unique
  notes         String?
  discountBD    Decimal?             @db.Decimal(10, 3)
  discountNote  String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  store         Store                @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@map("billing_invoices")
}

// ─────────────────────────────────────────────
// ADMIN NOTES (ملاحظات الإدارة الداخلية)
// ─────────────────────────────────────────────
model AdminNote {
  id          String   @id @default(cuid())
  merchantId  String
  content     String
  authorEmail String
  authorName  String
  createdAt   DateTime @default(now())

  @@index([merchantId])
  @@map("admin_notes")
}

// ─────────────────────────────────────────────
// PLAN CONFIG (إعدادات الباقات)
// ─────────────────────────────────────────────
model PlanConfig {
  id          String    @id @default(cuid())
  plan        StorePlan @unique
  priceBD     Decimal   @db.Decimal(10, 3)
  maxProducts Int       @default(100)
  maxOrders   Int       @default(500)
  maxStaff    Int       @default(1)
  maxApps     Int       @default(0)
  features    String[]
  updatedAt   DateTime  @updatedAt

  @@map("plan_configs")
}

// ─────────────────────────────────────────────
// APP STORE (متجر التطبيقات)
// ─────────────────────────────────────────────
model App {
  id            String          @id @default(cuid())
  slug          String          @unique
  name          String
  nameAr        String
  description   String
  descriptionAr String
  icon          String?
  category      AppCategory
  developer     String
  developerEmail String?
  webhookUrl    String?
  isOfficial    Boolean         @default(false)
  isApproved    Boolean         @default(false)
  pricingType   AppPricingType  @default(FREE)
  monthlyPrice  Decimal?        @db.Decimal(10, 3)
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  installs      InstalledApp[]

  @@map("apps")
}

model InstalledApp {
  id          String    @id @default(cuid())
  storeId     String
  appId       String
  isActive    Boolean   @default(true)
  config      Json?
  installedAt DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  app         App       @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([storeId, appId])
  @@map("installed_apps")
}

// ─────────────────────────────────────────────
// BLOG (المدونة)
// ─────────────────────────────────────────────
model BlogPost {
  id          String    @id @default(cuid())
  storeId     String
  title       String
  titleAr     String?
  slug        String
  content     String
  contentAr   String?
  excerpt     String?
  coverImage  String?
  isPublished Boolean   @default(false)
