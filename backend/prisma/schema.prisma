// This is your Prisma schema file for Bazar Platform
// Developer: BSMC.BH

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// MERCHANTS (التجار)
// ─────────────────────────────────────────────
model Merchant {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  isVerified    Boolean   @default(false)
  isActive      Boolean   @default(true)
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  stores        Store[]
  sessions      Session[]

  @@map("merchants")
}

model Session {
  id           String   @id @default(cuid())
  merchantId   String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  merchant     Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─────────────────────────────────────────────
// STORES (المتاجر)
// ─────────────────────────────────────────────
model Store {
  id           String      @id @default(cuid())
  merchantId   String
  name         String
  nameAr       String
  slug         String      @unique
  description  String?
  descriptionAr String?
  logo         String?
  favicon      String?
  domain       String?     @unique
  subdomain    String      @unique
  currency     String      @default("BHD")
  language     StoreLanguage @default(BOTH)
  timezone     String      @default("Asia/Bahrain")
  vatNumber    String?
  crNumber     String?
  vatRate      Decimal     @default(0.05) @db.Decimal(5, 4)
  isActive     Boolean     @default(true)
  plan         StorePlan   @default(STARTER)
  planExpiresAt DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  merchant     Merchant    @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  products     Product[]
  categories   Category[]
  orders       Order[]
  customers    Customer[]
  coupons      Coupon[]
  pages        Page[]
  settings     StoreSettings?

  @@map("stores")
}

model StoreSettings {
  id             String  @id @default(cuid())
  storeId        String  @unique
  primaryColor   String  @default("#2563eb")
  secondaryColor String  @default("#f97316")
  theme          String  @default("default")
  showOutOfStock Boolean @default(true)
  allowReviews   Boolean @default(true)
  freeShippingMin Decimal? @db.Decimal(10, 3)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  store          Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("store_settings")
}

// ─────────────────────────────────────────────
// CATEGORIES (التصنيفات)
// ─────────────────────────────────────────────
model Category {
  id          String     @id @default(cuid())
  storeId     String
  parentId    String?
  name        String
  nameAr      String
  slug        String
  description String?
  image       String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  store       Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  parent      Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryChildren")
  products    Product[]

  @@unique([storeId, slug])
  @@map("categories")
}

// ─────────────────────────────────────────────
// PRODUCTS (المنتجات)
// ─────────────────────────────────────────────
model Product {
  id              String        @id @default(cuid())
  storeId         String
  categoryId      String?
  name            String
  nameAr          String
  slug            String
  description     String?
  descriptionAr   String?
  sku             String?
  barcode         String?
  price           Decimal       @db.Decimal(10, 3)
  comparePrice    Decimal?      @db.Decimal(10, 3)
  costPrice       Decimal?      @db.Decimal(10, 3)
  trackInventory  Boolean       @default(true)
  stock           Int           @default(0)
  lowStockAlert   Int           @default(5)
  weight          Decimal?      @db.Decimal(8, 3)
  isActive        Boolean       @default(true)
  isFeatured      Boolean       @default(false)
  isDigital       Boolean       @default(false)
  digitalFileUrl  String?
  seoTitle        String?
  seoDescription  String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  store           Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category        Category?     @relation(fields: [categoryId], references: [id])
  images          ProductImage[]
  variants        ProductVariant[]
  orderItems      OrderItem[]

  @@unique([storeId, slug])
  @@map("products")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int     @default(0)

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductVariant {
  id         String   @id @default(cuid())
  productId  String
  name       String
  nameAr     String
  sku        String?
  price      Decimal  @db.Decimal(10, 3)
  stock      Int      @default(0)
  image      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@map("product_variants")
}

// ─────────────────────────────────────────────
// CUSTOMERS (العملاء)
// ─────────────────────────────────────────────
model Customer {
  id           String    @id @default(cuid())
  storeId      String
  email        String?
  phone        String
  firstName    String
  lastName     String
  passwordHash String?
  isGuest      Boolean   @default(false)
  totalOrders  Int       @default(0)
  totalSpent   Decimal   @default(0) @db.Decimal(10, 3)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  store        Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders       Order[]
  addresses    Address[]

  @@unique([storeId, phone])
  @@map("customers")
}

model Address {
  id         String   @id @default(cuid())
  customerId String
  label      String   @default("المنزل")
  firstName  String
  lastName   String
  phone      String
  block      String?
  road       String?
  building   String?
  flat       String?
  area       String
  city       String   @default("المنامة")
  country    String   @default("BH")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders     Order[]

  @@map("addresses")
}

// ─────────────────────────────────────────────
// ORDERS (الطلبات)
// ─────────────────────────────────────────────
model Order {
  id              String        @id @default(cuid())
  storeId         String
  customerId      String
  addressId       String?
  orderNumber     String
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentMethod   PaymentMethod
  subtotal        Decimal       @db.Decimal(10, 3)
  shippingCost    Decimal       @default(0) @db.Decimal(10, 3)
  vatAmount       Decimal       @default(0) @db.Decimal(10, 3)
  discountAmount  Decimal       @default(0) @db.Decimal(10, 3)
  total           Decimal       @db.Decimal(10, 3)
  couponCode      String?
  notes           String?
  trackingNumber  String?
  shippingCompany String?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  store           Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer        Customer      @relation(fields: [customerId], references: [id])
  address         Address?      @relation(fields: [addressId], references: [id])
  items           OrderItem[]
  payment         Payment?

  @@unique([storeId, orderNumber])
  @@map("orders")
}

model OrderItem {
  id        String          @id @default(cuid())
  orderId   String
  productId String
  variantId String?
  name      String
  nameAr    String
  sku       String?
  price     Decimal         @db.Decimal(10, 3)
  quantity  Int
  total     Decimal         @db.Decimal(10, 3)

  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id])
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

// ─────────────────────────────────────────────
// PAYMENTS (المدفوعات)
// ─────────────────────────────────────────────
model Payment {
  id            String        @id @default(cuid())
  orderId       String        @unique
  method        PaymentMethod
  amount        Decimal       @db.Decimal(10, 3)
  currency      String        @default("BHD")
  status        PaymentStatus @default(PENDING)
  gatewayRef    String?
  gatewayResponse Json?
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ─────────────────────────────────────────────
// COUPONS (الكوبونات)
// ─────────────────────────────────────────────
model Coupon {
  id            String      @id @default(cuid())
  storeId       String
  code          String
  type          CouponType
  value         Decimal     @db.Decimal(10, 3)
  minOrderValue Decimal?    @db.Decimal(10, 3)
  maxUses       Int?
  usedCount     Int         @default(0)
  isActive      Boolean     @default(true)
  expiresAt     DateTime?
  createdAt     DateTime    @default(now())

  store         Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, code])
  @@map("coupons")
}

// ─────────────────────────────────────────────
// PAGES (صفحات المتجر)
// ─────────────────────────────────────────────
model Page {
  id          String   @id @default(cuid())
  storeId     String
  title       String
  titleAr     String
  slug        String
  content     String?
  contentAr   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, slug])
  @@map("pages")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────
enum StoreLanguage {
  AR
  EN
  BOTH
}

enum StorePlan {
  STARTER
  GROWTH
  PRO
  ENTERPRISE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  BENEFIT_PAY
  CREDIMAX
  VISA_MASTERCARD
  APPLE_PAY
  GOOGLE_PAY
  CASH_ON_DELIVERY
  BANK_TRANSFER
  TABBY
  TAMARA
}

enum CouponType {
  PERCENTAGE
  FIXED
  FREE_SHIPPING
}
