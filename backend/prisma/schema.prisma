// ─────────────────────────────────────────────
// EMAIL MARKETING (التسويق بالبريد الإلكتروني)
// ─────────────────────────────────────────────
model EmailCampaign {
  id             String              @id @default(cuid())
  storeId        String
  name           String
  subject        String?
  subjectAr      String?
  body           String?
  bodyAr         String?
  status         EmailCampaignStatus @default(DRAFT)
  scheduledAt    DateTime?
  sentAt         DateTime?
  recipientCount Int                 @default(0)
  openCount      Int                 @default(0)
  clickCount     Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  store          Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("email_campaigns")
}

model EmailSubscriber {
  id              String    @id @default(cuid())
  storeId         String
  email           String
  firstName       String?
  lastName        String?
  tags            String[]
  isActive        Boolean   @default(true)
  source          String    @default("STOREFRONT")
  subscribedAt    DateTime  @default(now())
  unsubscribedAt  DateTime?

  store           Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, email])
  @@map("email_subscribers")
}

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
}

// ─────────────────────────────────────────────
// ANNOUNCEMENTS (الإعلانات - للمنصة)
// ─────────────────────────────────────────────
model Announcement {
  id        String           @id @default(cuid())
  title     String
  titleAr   String
  body      String?
  bodyAr    String?
  type      AnnouncementType @default(INFO)
  isActive  Boolean          @default(true)
  isPinned  Boolean          @default(false)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@map("announcements")
}

enum AnnouncementType {
  INFO
  WARNING
  MAINTENANCE
  FEATURE
}

// ─────────────────────────────────────────────
// HELP CENTER (مركز المساعدة)
// ─────────────────────────────────────────────
model HelpArticle {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  titleAr     String
  body        String
  bodyAr      String
  category    String   @default("general")
  categoryAr  String   @default("عام")
  isPublished Boolean  @default(false)
  sortOrder   Int      @default(0)
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("help_articles")
}

// ─────────────────────────────────────────────
// UPSELL / CROSS-SELL RULES
// ─────────────────────────────────────────────
model UpsellRule {
  id                String   @id @default(cuid())
  storeId           String
  name              String
  title             String?
  titleAr           String?
  isActive          Boolean  @default(true)
  triggerType       String   @default("ANY") // ANY | SPECIFIC_PRODUCT | SPECIFIC_CATEGORY
  triggerProductId  String?
  triggerCategoryId String?
  offerProductIds   String[]
  discountPct       Decimal? @db.Decimal(5, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  store             Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("upsell_rules")
}

// ─────────────────────────────────────────────
// COUNTDOWN TIMERS (العدادات التنازلية)
// ─────────────────────────────────────────────
model CountdownTimer {
  id          String   @id @default(cuid())
  storeId     String
  name        String
  title       String?
  titleAr     String?
  endsAt      DateTime
  isActive    Boolean  @default(true)
  showOnAllPages Boolean @default(false)
  targetUrl   String?
  style       String   @default("BAR") // BAR | POPUP | INLINE
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("countdown_timers")
}
